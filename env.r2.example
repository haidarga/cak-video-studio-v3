# Cloudflare R2 — required after migrating away from Supabase Storage.
#
# Get these from Cloudflare dashboard:
#   - R2_ACCOUNT_ID:    Dashboard top-right user menu OR R2 page sidebar
#   - R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY:
#       R2 → Manage R2 API Tokens → Create API token → Object Read & Write
#       Bucket: cak-video-refs only. TTL: forever.
#   - R2_BUCKET:        the bucket name you created (default: cak-video-refs)
#   - R2_PUBLIC_URL:    your custom domain (https://cdn.cakvideo.com)
#                       OR the r2.dev subdomain (https://pub-xxxxx.r2.dev)
#
# Copy to .env.local for local dev, and add to Vercel project env vars
# (Production + Preview + Development scopes) before deploying.

R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cak-video-refs
R2_PUBLIC_URL=

# Only needed for the one-time migration script (scripts/migrate-supabase-to-r2.mjs):
# Service role key has full DB access — DO NOT add to Vercel client-side env.
# Keep in .env.local during migration only, then remove.
# SUPABASE_SERVICE_ROLE_KEY=
