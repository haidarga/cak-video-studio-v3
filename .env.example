# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only (NEVER expose to client) — bypasses RLS
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postiz (CakAI Pro instance)
POSTIZ_API_URL=https://your-postiz-instance.example.com
POSTIZ_API_KEY=

# fal.ai + Gemini — workspace defaults (can be overridden per-workspace later)
FAL_KEY=
GEMINI_KEY=

# Worker URL (HF Space that runs Remotion render + ffmpeg)
WORKER_URL=https://cahmul2-cak-video-studio-v2.hf.space
